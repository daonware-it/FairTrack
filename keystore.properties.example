# Vorlage für lokale Release-Builds. Kopieren nach `keystore.properties`
# (gitignored) und die echten Werte eintragen. In der CI kommen dieselben
# Werte stattdessen aus den Umgebungsvariablen KEYSTORE_FILE,
# KEYSTORE_PASSWORD, KEY_ALIAS und KEY_PASSWORD.
#
# Ohne diese Datei und ohne die Umgebungsvariablen baut `assembleRelease`
# weiterhin durch, das Ergebnis ist dann aber unsigniert.

storeFile=upload-keystore.jks
storePassword=
keyAlias=fairtrack-upload
keyPassword=
